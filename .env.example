# Telegram bot required settings
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_ID=123456789
LOG_CHANNEL=-1001234567890
STORAGE_CHANNEL_ID=-1001234567890

# Optional: Use a secondary bot for share links (if set, share links will use this bot)
BOT_TOKEN1=YOUR_SECONDARY_BOT_TOKEN_HERE

# Optional settings
FILE_EXPIRY_MINUTES=5
NEVER_EXPIRE_LINKS=1
CLEANUP_INTERVAL_MINUTES=1
BROADCAST_CLEANUP_INTERVAL_MINUTES=30

# Optional: Require users to join channels before accessing files via BOT_TOKEN1
# Comma-separated list of channel invite links (e.g., https://t.me/+channelname or https://t.me/@publicchannel)
JOIN_CHANNEL_LINK=https://t.me/+channel1,https://t.me/+channel2

# Optional: Supabase backend
USE_SUPABASE=0
+SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_OR_SB_SECRET
